# ATAP Environment Configuration
# This file is only used if you want to customise default paths.
# Rename to .env and adjust as needed.

# Default folder where projects will be saved (relative to app)
# DEFAULT_SAVE_DIR=./saves

# Enable debug mode (shows extra console output)
# DEBUG=false

# Custom colour palette (comma‑separated hex values)
# CUSTOM_COLORS=#FF0000,#00FF00,#0000FF

# Interface language (currently only "en" is supported)
# LANGUAGE=en